{
  "expo": {
    "name": "Die Hellen",
    "slug": "stammtisch-app",
    "scheme": "stammtisch-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A4480"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.diehellen.stammtischapp",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.diehellen.stammtischapp",
      "adaptiveIcon": {
        "backgroundColor": "#1A4480",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Stammtisch möchte auf deine Fotos zugreifen, um ein Profilbild hinzuzufügen.",
          "cameraPermission": "Stammtisch möchte die Kamera nutzen, um ein Profilfoto aufzunehmen."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a5470a5d-eb6b-47c1-96ef-890a746cd26d"
      }
    },
    "owner": "joshmb"
  }
}
